# ─────────────────────────────────────────────────────────────────────────────
#  Gunaso — Environment Variables Template (Docker Compose stack)
#  Copy this file to .env and fill in real values before starting the stack.
#  NEVER commit .env to version control.
#
#  Generate strong keys:
#    python -c "import secrets; print(secrets.token_urlsafe(64))"
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
# Set DEBUG=False in production. With DEBUG=False, SECRET_KEY is REQUIRED.
DEBUG=True
SECRET_KEY=change-me-generate-50-plus-random-chars
JWT_SIGNING_KEY=change-me-generate-a-separate-random-key
# With DEBUG=True, *.ngrok-free.app / *.ngrok.app / *.ngrok.io hosts are
# accepted automatically (dev tunnels). In production list every host here.
ALLOWED_HOSTS=localhost,127.0.0.1

# Behind plain-HTTP nginx in local dev keep this False.
# Set to True in production once TLS is terminated in front of the stack.
SECURE_SSL_REDIRECT=False

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# The backend's DATABASE_URL is assembled from these values in docker-compose.yml.
POSTGRES_DB=gunaso_db
POSTGRES_USER=gunaso_user
POSTGRES_PASSWORD=change-me-db-password

# ── CORS / CSRF ───────────────────────────────────────────────────────────────
# Explicit allowlists. Add your production domain(s) here.
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:3000

# ── Uploads ───────────────────────────────────────────────────────────────────
MAX_ATTACHMENT_SIZE_MB=10

# ── Email (optional — defaults to console backend) ───────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@gunaso.gov.np
