# ─────────────────────────────────────────────────────────────────────────────
#  Gunaso — Environment Variables Template
#  Copy this file to .env and fill in real values before starting the stack.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-me-in-production-use-50-random-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_DB=gunaso_db
POSTGRES_USER=gunaso_user
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql://gunaso_user:change-me-db-password@postgres:5432/gunaso_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_SIGNING_KEY=change-me-jwt-signing-key

# ── Email ─────────────────────────────────────────────────────────────────────
# For local dev, use console backend. Switch to SMTP for staging/prod.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@gunaso.gov.np

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost/api/v1
VITE_WS_BASE_URL=ws://localhost/ws

# ── File Storage ──────────────────────────────────────────────────────────────
# Set USE_S3=True and fill AWS credentials for production S3 storage.
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_CUSTOM_DOMAIN=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ── Platform Settings ─────────────────────────────────────────────────────────
# Max file attachments allowed per submission
MAX_ATTACHMENT_SIZE_MB=10
MAX_ATTACHMENTS_PER_SUBMISSION=5
# Escalation delay in days (auto-escalate if no response after N days)
AUTO_ESCALATION_DAYS=7
