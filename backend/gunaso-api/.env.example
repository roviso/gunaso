# Gunaso API — local development environment (bare metal, without Docker).
# Copy to .env and adjust. For the full Docker stack use the root .env instead.

DEBUG=True
SECRET_KEY=dev-only-change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL unset to use a local sqlite file (quick dev),
# or point it at a local PostgreSQL 16 instance:
# DATABASE_URL=postgresql://gunaso_user:password@localhost:5432/gunaso_db

# Optional local Redis for shared rate-limit counters:
# REDIS_URL=redis://localhost:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# How many days a staff invite link stays valid before it expires (default 7).
# STAFF_INVITE_EXPIRY_DAYS=7

# AI features (apps.ai_insights) — classification, sujhav, reports. Leave
# unset to run with AI features disabled (the app still works fully without
# it; AI-only endpoints return 503).
# ANTHROPIC_API_KEY=sk-ant-...
# AI_CLASSIFICATION_MODEL=claude-opus-4-8
# THROTTLE_AI_CLASSIFY=30/hour
# THROTTLE_AI_SUGGESTION=20/hour
